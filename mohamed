    <script>
        // ========== البيانات ==========
        let adminPassword = 'admin123';
        let isLoggedIn = false;
        let messages = JSON.parse(localStorage.getItem('messages')) || [];
        let files = JSON.parse(localStorage.getItem('files')) || [];
        let totalDownloads = parseInt(localStorage.getItem('totalDownloads')) || 0;

        // ========== الإحصائيات ==========
        function updateStats() {
            document.getElementById('statDownloads').textContent = totalDownloads;
        }

        // ========== الأصوات ==========
        function playSound() {
            try {
                const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                const oscillator = audioContext.createOscillator();
                const gainNode = audioContext.createGain();
                oscillator.connect(gainNode);
                gainNode.connect(audioContext.destination);
                oscillator.frequency.value = 800;
                oscillator.type = 'sine';
                gainNode.gain.setValueAtTime(0.2, audioContext.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.1);
                oscillator.start(audioContext.currentTime);
                oscillator.stop(audioContext.currentTime + 0.1);
            } catch(e) { console.log('Audio not supported'); }
        }

        // ========== التنقل ==========
        function showSection(sectionId) {
            document.querySelectorAll('section').forEach(s => s.classList.remove('active'));
            document.getElementById(sectionId).classList.add('active');
            window.scrollTo(0, 0);
        }

        function showNotification(message, isError = false) {
            const notification = document.createElement('div');
            notification.className = 'notification';
            notification.style.background = isError ? '#ff3333' : '#0066cc';
            notification.textContent = message;
            document.body.appendChild(notification);
            setTimeout(() => {
                notification.style.animation = 'slideIn 0.3s reverse';
                setTimeout(() => notification.remove(), 300);
            }, 3000);
        }

        // ========== إدارة الملفات (للمدير) ==========
        function addFile(event) {
            event.preventDefault();
            const file = {
                id: Date.now(),
                name: document.getElementById('fileName').value,
                description: document.getElementById('fileDesc').value,
                link: document.getElementById('fileLink').value,
                password: document.getElementById('filePassword').value || '',
                downloads: 0,
                date: new Date().toLocaleDateString('ar-EG')
            };
            files.push(file);
            localStorage.setItem('files', JSON.stringify(files));
            event.target.reset();
            loadFilesList();
            loadPublicDownloads();
            showNotification('✅ تم إضافة الملف بنجاح!');
        }

        function loadFilesList() {
            const container = document.getElementById('filesList');
            if (!container) return;
            if (files.length === 0) {
                container.innerHTML = '<p>لا توجد ملفات مضافة</p>';
                return;
            }
            container.innerHTML = files.map(file => `
                <div class="file-item">
                    <div class="file-info">
                        <strong>${file.name}</strong><br>
                        <small>${file.description}</small><br>
                        <small>📥 ${file.downloads} تحميل | 📅 ${file.date}</small>
                        ${file.password ? '<span class="badge">🔒 محمي</span>' : '<span class="badge">🔓 مفتوح</span>'}
                    </div>
                    <div class="file-actions">
                        <button onclick="editFile(${file.id})">✏️ تعديل</button>
                        <button onclick="deleteFile(${file.id})" style="background:#ff3333;">🗑️ حذف</button>
                    </div>
                </div>
            `).join('');
        }

        function editFile(id) {
            const file = files.find(f => f.id === id);
            if (!file) return;
            const newName = prompt('الاسم الجديد:', file.name);
            const newDesc = prompt('الوصف الجديد:', file.description);
            const newLink = prompt('رابط التحميل الجديد:', file.link);
            const newPass = prompt('كلمة السر الجديدة (اتركها فارغة للإزالة):', file.password);
            if (newName) file.name = newName;
            if (newDesc) file.description = newDesc;
            if (newLink) file.link = newLink;
            file.password = newPass || '';
            localStorage.setItem('files', JSON.stringify(files));
            loadFilesList();
            loadPublicDownloads();
            showNotification('✅ تم تعديل الملف!');
        }

        function deleteFile(id) {
            if (confirm('هل تريد حذف هذا الملف؟')) {
                files = files.filter(f => f.id !== id);
                localStorage.setItem('files', JSON.stringify(files));
                loadFilesList();
                loadPublicDownloads();
                showNotification('✅ تم حذف الملف!');
            }
        }

        // ========== عرض الملفات للزوار ==========
        function loadPublicDownloads() {
            const container = document.getElementById('publicDownloadsList');
            if (!container) return;
            if (files.length === 0) {
                container.innerHTML = '<p>📭 لا توجد ملفات متاحة للتحميل حالياً</p>';
                return;
            }
            container.innerHTML = files.map(file => `
                <div class="card">
                    <h4>📄 ${file.name}</h4>
                    <p>${file.description}</p>
                    <small>📅 أضيف في: ${file.date}</small>
                    ${file.password ? 
                        `<button onclick="requestPassword(${file.id})">🔒 تحميل (محمي)</button>` :
                        `<button onclick="downloadFileById(${file.id})">⬇️ تحميل</button>`
                    }
                </div>
            `).join('');
        }

        function requestPassword(fileId) {
            const file = files.find(f => f.id === fileId);
            if (!file) return;
            const modal = document.createElement('div');
            modal.className = 'password-modal';
            modal.innerHTML = `
                <div class="password-modal-content">
                    <h3>🔒 ملف محمي</h3>
                    <p>${file.name}</p>
                    <input type="password" id="modalPassword" placeholder="أدخل كلمة السر">
                    <button onclick="verifyAndDownload(${fileId})">تأكيد</button>
                    <button onclick="this.closest('.password-modal').remove()">إلغاء</button>
                </div>
            `;
            document.body.appendChild(modal);
        }

        function verifyAndDownload(fileId) {
            const password = document.getElementById('modalPassword')?.value;
            const file = files.find(f => f.id === fileId);
            if (file.password && file.password !== password) {
                alert('❌ كلمة السر غير صحيحة');
                return;
            }
            document.querySelector('.password-modal')?.remove();
            downloadFileById(fileId);
        }

        function downloadFileById(fileId) {
            const file = files.find(f => f.id === fileId);
            if (file && file.link) {
                file.downloads = (file.downloads || 0) + 1;
                totalDownloads++;
                localStorage.setItem('files', JSON.stringify(files));
                localStorage.setItem('totalDownloads', totalDownloads);
                updateStats();
                window.open(file.link, '_blank');
                showNotification(`⬇️ جاري تحميل: ${file.name}`);
                if (isLoggedIn) loadFilesList();
            } else {
                showNotification('❌ رابط التحميل غير صالح', true);
            }
        }

        // ========== إدارة الرسائل ==========
        function sendMessage(event) {
            event.preventDefault();
            const message = {
                id: Date.now(),
                name: document.getElementById('name').value,
                email: document.getElementById('email').value,
                phone: document.getElementById('phone').value || 'غير مدخل',
                subject: document.getElementById('subject').value,
                message: document.getElementById('message').value,
                date: new Date().toLocaleString('ar-EG')
            };
            messages.push(message);
            localStorage.setItem('messages', JSON.stringify(messages));
            event.target.reset();
            showNotification('✅ تم إرسال رسالتك بنجاح!');
        }

        function loadMessages() {
            const container = document.getElementById('messagesList');
            if (!container) return;
            if (messages.length === 0) {
                container.innerHTML = '<p>لا توجد رسائل</p>';
                return;
            }
            container.innerHTML = messages.map(msg => `
                <div class="message-item">
                    <strong>${msg.name}</strong> - ${msg.date}<br>
                    <small>📧 ${msg.email} | 📱 ${msg.phone}</small>
                    <p><strong>الموضوع:</strong> ${msg.subject}</p>
                    <p>${msg.message}</p>
                    <button onclick="deleteMessage(${msg.id})" style="background:#ff3333;">حذف</button>
                </div>
            `).join('');
        }

        function deleteMessage(id) {
            if (confirm('حذف الرسالة؟')) {
                messages = messages.filter(m => m.id !== id);
                localStorage.setItem('messages', JSON.stringify(messages));
                loadMessages();
                showNotification('✅ تم حذف الرسالة');
            }
        }

        // ========== أدوات وألعاب ==========
        function colorTool() { prompt('🎨 محرر الألوان\nأدخل لون بالعربي أو الإنجليزي:', 'أحمر'); }
        function passwordGenerator() { 
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';
            let pass = '';
            for(let i=0; i<12; i++) pass += chars[Math.floor(Math.random() * chars.length)];
            prompt('🔐 كلمة السر المقترحة:', pass);
        }
        function textConverter() { 
            const text = prompt('📝 أدخل النص:', 'مرحبا بالعالم');
            if(text) alert(` uppercase: ${text.toUpperCase()}\n lowercase: ${text.toLowerCase()}`);
        }
        function showCourse(course) { showNotification(`📚 كورس ${course} - سيتم إطلاقه قريباً!`); }
        function memoryGame() { showNotification('🎮 لعبة الذاكرة - قريباً!'); }
        function snakeGame() { showNotification('🐍 لعبة الثعبان - قريباً!'); }
        function numberGame() { 
            const random = Math.floor(Math.random() * 100) + 1;
            alert('🎲 لعبة تخمين الرقم!\nحاول تخمين رقم بين 1 و 100');
        }
        function showNews() { showNotification('📰 سيتم إضافة الأخبار قريباً - تابعنا!'); }

        // ========== لوحة التحكم ==========
        function loginAdmin(event) {
            event.preventDefault();
            const password = document.getElementById('password').value;
            if (password === adminPassword) {
                isLoggedIn = true;
                document.getElementById('loginForm').style.display = 'none';
                document.getElementById('adminPanel').style.display = 'block';
                loadFilesList();
                loadMessages();
                showNotification('✅ تم تسجيل الدخول!');
            } else {
                showNotification('❌ كلمة السر غير صحيحة!', true);
            }
        }

        function logoutAdmin() {
            isLoggedIn = false;
            document.getElementById('loginForm').style.display = 'block';
            document.getElementById('adminPanel').style.display = 'none';
            document.getElementById('password').value = '';
            showSection('home');
            showNotification('👋 تم تسجيل الخروج');
        }

        function changePassword(event) {
            event.preventDefault();
            const oldPass = document.getElementById('oldPassword').value;
            const newPass = document.getElementById('newPassword').value;
            if (oldPass === adminPassword) {
                adminPassword = newPass;
                event.target.reset();
                showNotification('✅ تم تغيير كلمة السر!');
            } else {
                showNotification('❌ كلمة السر القديمة غير صحيحة!', true);
            }
        }

        function showAdminLogin() { showSection('admin'); }

        // ========== التحميل الأولي ==========
        window.addEventListener('load', () => {
            updateStats();
            loadPublicDownloads();
        });
    </script>
</body>
</html>
