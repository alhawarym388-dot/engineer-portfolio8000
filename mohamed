            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0066cc 0%, #ff3333 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            overflow: hidden;
        }

        header {
            background: linear-gradient(135deg, #0066cc 0%, #ff3333 100%);
            color: white;
            padding: 40px 20px;
            text-align: center;
        }

        header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        header p {
            font-size: 1.3em;
            opacity: 0.9;
        }

        nav {
            background: #222;
            padding: 0;
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            overflow-y: auto;
            max-height: 120px;
        }

        nav a, nav button {
            color: white;
            padding: 15px 20px;
            text-decoration: none;
            cursor: pointer;
            border: none;
            background: none;
            font-size: 0.95em;
            transition: all 0.3s;
            white-space: nowrap;
        }

        nav a:hover, nav button:hover {
            background: linear-gradient(135deg, #0066cc 0%, #ff3333 100%);
            transform: scale(1.1);
        }

        main {
            padding: 40px;
        }

        section {
            margin-bottom: 40px;
            display: none;
            animation: fadeIn 0.5s;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px);}
            to { opacity: 1; transform: translateY(0);}
        }

        section.active {
            display: block;
        }

        h2 {
            background: linear-gradient(135deg, #0066cc 0%, #ff3333 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 20px;
            font-size: 2em;
            border-bottom: 3px solid #ff3333;
            padding-bottom: 10px;
        }

        h3 {
            color: #0066cc;
            margin-top: 20px;
            margin-bottom: 15px;
        }

        .card {
            background: linear-gradient(135deg, #f0f8ff 0%, #fff0f5 100%);
            padding: 20px;
            margin: 15px 0;
            border-radius: 10px;
            border-left: 5px solid #ff3333;
            transition: all 0.3s;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        }

        .card:hover {
            transform: translateX(10px);
